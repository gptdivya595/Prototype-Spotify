# --- LLM (OpenAI) ---
OPENAI_API_KEY=sk-...
DEFAULT_MODEL=gpt-4o-mini          # tagging + cheap synthesis
SYNTHESIS_MODEL=gpt-4o             # grounded RAG answers (optional; falls back to DEFAULT_MODEL)
EMBEDDING_MODEL=text-embedding-3-small

# Optional: force the retained local app-store-scraper adapter. Default is Apple RSS because
# the legacy adapter currently returns zero Spotify reviews; RSS is used as its fallback.
# APPLE_REVIEW_ADAPTER=legacy

# --- Vector store (Upstash Vector) ---
UPSTASH_VECTOR_REST_URL=https://...upstash.io
UPSTASH_VECTOR_REST_TOKEN=...

# --- Optional cache (Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional hosted ingestion (keep disabled for the read-only Vercel release) ---
# ALLOW_REMOTE_INGEST=false
# INGEST_ADMIN_KEY=generate-a-long-random-secret

# --- Optional Reddit (only if using PRAW instead of public JSON) ---
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
