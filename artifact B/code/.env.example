# Copy this file to .env.local and use a newly rotated key.
# Never commit a real credential.
OPENAI_API_KEY=replace-with-your-openai-api-key
DEFAULT_MODEL=gpt-4o-mini

# Memory is for local development only; Postgres is required for hosted evaluation.
EVENT_STORE_MODE=memory
DATABASE_URL=
INTERVIEWS_COMPLETE=false

# Optional server-side study configuration.
STUDY_VERSION=discovery-compass-v1
